# ---------------------------------------------------------------------------
# Copy to .env and adjust. Compose reads this file automatically.
# ---------------------------------------------------------------------------

# App
APP_NAME=workspace-aggregator
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=true

# Postgres
POSTGRES_USER=aggregator
POSTGRES_PASSWORD=aggregator
POSTGRES_DB=aggregator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (Celery broker + result backend)
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO / S3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=attachments
S3_REGION=us-east-1

# --- Connectors -------------------------------------------------------------
# GitHub Issues connector (the implemented vertical slice).
# Personal access token with `repo` (or `public_repo`) scope.
GITHUB_TOKEN=
# Repos to sync, comma-separated "owner/name".
GITHUB_REPOS=pydantic/pydantic

# Telegram connector (stub — long polling)
TELEGRAM_BOT_TOKEN=

# Email / IMAP connector.
# For local e2e use the bundled greenmail (docker compose --profile mail):
#   IMAP_HOST=greenmail  IMAP_PORT=3143  IMAP_USE_SSL=false  (user/pass: anything)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX

# --- Optional vector module (feature-flagged) -------------------------------
# Enable Qdrant: docker compose --profile vector up -d qdrant, then VECTOR_ENABLED=true
VECTOR_ENABLED=false
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=messages
# Embedding provider: "hash" (deterministic, no deps/keys) or "openai".
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=256
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536
